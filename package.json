{
  "name": "olybars-production",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/dist/server/src/index.js",
    "gcp-build": "echo 'Skipping cloud build, using uploaded artifacts'",
    "server": "nodemon --exec tsx server/src/index.ts",
    "build:dev": "vite build --mode development",
    "build:prod": "node scripts/clean-dist.js && vite build --mode production --emptyOutDir",
    "build:server": "tsc -p server",
    "smoke:dev": "curl.exe -fI https://ama-ecosystem-dev-9ceda.web.app/ && curl.exe -f https://ama-ecosystem-dev-9ceda.web.app/api/health",
    "smoke:prod": "curl.exe -fI https://olybars.com/ && curl.exe -f https://olybars.com/api/health",
    "artie:sync": "node --import tsx functions/src/scripts/sync-artie-kb.ts",
    "artie:check": "node --import tsx scripts/verify-artie-health.ts",
    "seed:dev": "node --import tsx server/src/seed.ts --cloud",
    "seed:prod": "node --import tsx server/src/seed.ts --force-prod --yes",
    "deploy:firestore:dev": "firebase deploy -P staging --only firestore",
    "deploy:firestore:prod": "firebase deploy -P default --only firestore",
    "deploy:functions:dev": "firebase deploy -P staging --only functions",
    "deploy:functions:prod": "firebase deploy -P default --only functions",
    "deploy:backend:dev": "gcloud run deploy olybars-backend --source . --project ama-ecosystem-dev-9ceda --region us-west1 --allow-unauthenticated --set-env-vars FRONTEND_URL=https://ama-ecosystem-dev-9ceda.web.app,NODE_ENV=production --set-secrets VITE_GOOGLE_BROWSER_KEY=VITE_GOOGLE_BROWSER_KEY:latest",
    "deploy:backend:prod": "gcloud run deploy olybars-backend --source . --project ama-ecosystem-prod --region us-west1 --allow-unauthenticated --set-env-vars FRONTEND_URL=https://olybars.com,NODE_ENV=production,GOOGLE_CLOUD_PROJECT=ama-ecosystem-prod,INTERNAL_HEALTH_TOKEN=oly-internal-default-shared --set-secrets VITE_GOOGLE_BROWSER_KEY=GOOGLE_BROWSER_KEY:latest,GOOGLE_BACKEND_KEY=GOOGLE_BACKEND_KEY:latest,MASTER_SETUP_KEY=MASTER_SETUP_KEY:latest",
    "deploy:dev": "cross-env GOOGLE_CLOUD_PROJECT=ama-ecosystem-dev-9ceda npm run artie:sync && npm run build:dev && node scripts/check-env.js development && npm run deploy:backend:dev && firebase deploy -P staging --only hosting:dev,firestore,functions && cross-env GOOGLE_CLOUD_PROJECT=ama-ecosystem-dev-9ceda npm run seed:dev && npm run smoke:dev",
    "deploy:prod": "cross-env GOOGLE_CLOUD_PROJECT=ama-ecosystem-prod npm run artie:sync && npm run build:prod && node scripts/check-env.js production && npm run deploy:backend:prod && firebase deploy -P default --only hosting:prod,firestore,functions && cross-env GOOGLE_CLOUD_PROJECT=ama-ecosystem-prod npm run seed:prod && npm run smoke:prod",
    "dev:all": "node --import tsx scripts/dev-up.ts",
    "generate-sitemap": "tsx scripts/generate-sitemap.ts",
    "guardrail:local": "cross-env SKIP_GUARDRAIL=false tsx scripts/guardrails/verify-env.ts local",
    "guardrail:dev": "tsx scripts/guardrails/verify-env.ts development",
    "guardrail:prod": "tsx scripts/guardrails/verify-env.ts production",
    "guardrail:finops": "tsx scripts/guardrails/verify-finops.ts",
    "guardrail:audit": "tsx scripts/guardrails/audit-compliance.ts",
    "guardrail:conn:local": "tsx scripts/guardrails/verify-connectivity.ts local",
    "guardrail:conn:dev": "tsx scripts/guardrails/verify-connectivity.ts development",
    "guardrail:conn:prod": "tsx scripts/guardrails/verify-connectivity.ts production",
    "sticky:local": "npm run guardrail:conn:local",
    "predev": "npm run guardrail:local",
    "predeploy:dev": "npm run guardrail:dev",
    "predeploy:prod": "npm run guardrail:prod",
    "prepare": "husky"
  },
  "dependencies": {
    "@genkit-ai/ai": "^1.27.0",
    "@genkit-ai/core": "^1.27.0",
    "@genkit-ai/dotprompt": "^0.9.12",
    "@genkit-ai/firebase": "^1.27.0",
    "@genkit-ai/flow": "^0.5.17",
    "@genkit-ai/googleai": "^1.27.0",
    "@genkit-ai/vertexai": "^1.27.0",
    "@google/genai": "^1.34.0",
    "@googlemaps/js-api-loader": "^1.16.8",
    "@tanstack/react-query": "^5.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "firebase": "^12.7.0",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.454.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-firebase-hooks": "^5.1.1",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0",
    "twilio": "^5.11.2",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "firebase-tools": "^15.3.1",
    "genkit-cli": "^1.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "vite": "^5.2.10",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*": "node --import tsx scripts/security/pre-commit-scanner.ts"
  }
}
