rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      // WARNING: This helper reads from the private users collection. 
      // Only used for server-side auth logic checks.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' || 
        request.auth.token.role == 'super-admin' || 
        request.auth.token.isAdmin == true ||
        // Legacy fallback for transition period
        getUserData().role == 'admin' || 
        getUserData().role == 'super-admin' || 
        getUserData().isAdmin == true
      );
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'super-admin' ||
        // Legacy fallback for transition period
        getUserData().role == 'super-admin'
      );
    }
    
    function isOwnerOf(venueId) {
      // Schmidt Logic: Verify specific venue ownership from token claims OR direct doc lookup
      return isAuthenticated() && (
        request.auth.token.role == 'owner' && request.auth.token.venueId == venueId ||
        getUserData().venuePermissions[venueId] == 'owner' ||
        get(/databases/$(database)/documents/venues/$(venueId)).data.ownerId == request.auth.uid
      );
    }

    // --- RULES ---

    // 1. PRIVATE USERS (PII Locked)
    match /users/{userId} {
      // Only the user themselves or Super Admin can read private data
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isSuperAdmin();
    }

    // 2. PUBLIC PROFILES (Safe for Leaderboards/Artie)
    match /public_profiles/{userId} {
      allow read: if true; // Publicly readable
      allow write: if false; // System-only write (Cloud Functions)
    }

    // 3. VENUES (The "Schmidt" Wall)
    match /venues/{venueId} {
      allow read: if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || isOwnerOf(venueId);
      allow delete: if isSuperAdmin();

      // Private Data Sub-collection: Restricted to authorized personnel only.
      match /private_data/{docId} {
        allow read, write: if isSuperAdmin() || isOwnerOf(venueId);
      }

      // Public Menu Items: Readable by all, Writable by Owner/Admin
      match /menuItems/{itemId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isOwnerOf(venueId);
      }

      // Scheduled Deals (Subcollection): Public Read
      match /scheduledDeals/{dealId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isOwnerOf(venueId);
      }
      
      // [NEW] Staff Invites (Mock Mode Logic)
      // Secure: Only Owners can create/delete. 
      // Open Read: Anyone with the token (ID) can read it to validate.
      // Refinement: In production, this read should be restricted to a Cloud Function.
      match /invites/{inviteId} {
         allow create, delete: if isSuperAdmin() || isOwnerOf(venueId);
         allow update: if true; // Temporary: Client-side "Accept" logic updates status. 
         // DANGER: The above update rule is very open, but locked by "Mock" requirement. 
         // In production, move acceptInvite() to Cloud Function.
         allow read: if true;
      }
    }

    // Signals: Managed by Backend API
    match /signals/{signalId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if false;
    }

    // System Notifications: Admin Only
    match /sys_admin_notifications/{notificationId} {
      allow create, read, update, delete: if isAdmin();
    }

    // 4. DEALS REGISTRY (Public Read)
    match /scheduled_deals_registry/{dealId} {
      allow read: if true;
    }

    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
